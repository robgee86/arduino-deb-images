++    exit(1);
+     fdevent_run_on_looper([this]() {
+         handle_offline(this);
+         transport_destroy(this);
diff -Nru android-platform-tools-34.0.5/debian/patches/adbd/adbd-use-bash.patch android-platform-tools-34.0.5/debian/patches/adbd/adbd-use-bash.patch
--- android-platform-tools-34.0.5/debian/patches/adbd/adbd-use-bash.patch	1970-01-01 00:00:00.000000000 +0000
+++ android-platform-tools-34.0.5/debian/patches/adbd/adbd-use-bash.patch	2025-08-25 10:08:19.000000000 +0000
@@ -0,0 +1,71 @@
+## Description: add some description
+## Origin/Author: add some origin or author
+## Bug: bug URL
+Index: android-platform-tools-34.0.5/packages/modules/adb/daemon/shell_service.cpp
+===================================================================
+--- android-platform-tools-34.0.5.orig/packages/modules/adb/daemon/shell_service.cpp
++++ android-platform-tools-34.0.5/packages/modules/adb/daemon/shell_service.cpp
+@@ -86,9 +86,11 @@
+ #include <pty.h>
+ #include <pwd.h>
+ #include <termios.h>
++#include <unistd.h>
+ 
+ #include <memory>
+ #include <string>
++#include <sys/types.h>
+ #include <thread>
+ #include <unordered_map>
+ #include <vector>
+@@ -111,6 +113,9 @@
+ #include "security_log_tags.h"
+ #include "shell_protocol.h"
+ 
++#undef _PATH_BSHELL
++#define _PATH_BSHELL "/bin/bash"
++
+ namespace {
+ 
+ // Reads from |fd| until close or failure.
+@@ -232,6 +237,23 @@ static std::string GetHostName() {
+     return android::base::GetProperty("ro.product.device", "android");
+ }
+ 
++/**
++ * Returns the home directory for the given UID
++ * default to "/" if not found
++ */
++std::string getHomeThreadSafe(uid_t uid) {
++    struct passwd pwd;
++    struct passwd* result = nullptr;
++    char buf[4096];
++
++    int rc = getpwuid_r(uid, &pwd, buf, sizeof(buf), &result);
++
++    if (rc == 0 && result != nullptr) {
++        return result->pw_dir;
++    }
++    return "/";
++}
++
+ bool Subprocess::ForkAndExec(std::string* error) {
+     unique_fd child_stdinout_sfd, child_stderr_sfd;
+     unique_fd parent_error_sfd, child_error_sfd;
+@@ -274,7 +296,7 @@ bool Subprocess::ForkAndExec(std::string
+         env["HOSTNAME"] = GetHostName();
+         env["LOGNAME"] = pw->pw_name;
+         env["SHELL"] = pw->pw_shell;
+-        env["TMPDIR"] = "/data/local/tmp";
++        env["TMPDIR"] = "/tmp";
+         env["USER"] = pw->pw_name;
+     }
+ 
+@@ -386,6 +408,8 @@ bool Subprocess::ForkAndExec(std::string
+         }
+ #endif
+ 
++        umask(0002);
++        chdir(getHomeThreadSafe(1000).c_str());
+         if (command_.empty()) {
+             // Spawn a login shell if we don't have a command.
+             execle(_PATH_BSHELL, "-" _PATH_BSHELL, nullptr, cenv.data());
