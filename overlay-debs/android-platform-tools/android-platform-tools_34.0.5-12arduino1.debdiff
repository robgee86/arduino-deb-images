diff -Nru android-platform-tools-34.0.5/debian/patches/adbd/adbd-drop-root.patch android-platform-tools-34.0.5/debian/patches/adbd/adbd-drop-root.patch
--- android-platform-tools-34.0.5/debian/patches/adbd/adbd-drop-root.patch	1970-01-01 00:00:00.000000000 +0000
+++ android-platform-tools-34.0.5/debian/patches/adbd/adbd-drop-root.patch	2025-08-25 10:08:19.000000000 +0000
@@ -0,0 +1,45 @@
+## Description: add some description
+## Origin/Author: add some origin or author
+## Bug: bug URL
+Index: android-platform-tools-34.0.5/packages/modules/adb/daemon/main.cpp
+===================================================================
+--- android-platform-tools-34.0.5.orig/packages/modules/adb/daemon/main.cpp
++++ android-platform-tools-34.0.5/packages/modules/adb/daemon/main.cpp
+@@ -51,6 +51,9 @@
+ 
+ #if defined(__linux__)
+ #include <systemd/sd-daemon.h>
++#include <grp.h>
++#include <unistd.h>
++#include <pwd.h>
+ #endif
+ 
+ #include "adb.h"
+@@ -305,6 +308,27 @@ int adbd_main(int server_port) {
+ 
+     LOG(INFO) << "adbd started";
+ 
++    /*
++     * Drops privileges to the user level and set the user's groups.
++     */
++    struct passwd *pw = getpwuid(1000);
++    if (pw == nullptr) {
++        LOG(ERROR) << "Failed to find user with UID 1000";
++        return 1;
++    }
++
++    if (initgroups(pw->pw_name, pw->pw_gid) != 0) {
++        LOG(ERROR) << "initgroups failed for user with UID 1000";
++        return 1;
++    }
++
++    if (setgid(1000) != 0) {
++        exit(1);
++    }
++    if (setuid(1000) != 0) {
++        exit(1);
++    }
++
+     D("adbd_main(): pre init_jdwp()");
+     init_jdwp();
+     D("adbd_main(): post init_jdwp()");
